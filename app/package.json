{
  "name": "betterfingers-electron",
  "version": "0.1.0",
  "description": "Electron shell for BetterFingers with a FastAPI Python backend.",
  "main": "out/main/main.js",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "electron-vite build",
    "build:backend": "node scripts/build-backend.js",
    "fix:electron": "node scripts/fix-electron.js",
    "test:unit": "node --test \"tests/**/*.test.mjs\"",
    "test:e2e": "playwright test",
    "qa:screens": "node tests/qa/run.mjs",
    "setup:llama:linux": "python3 ../tools/setup_linux_llama_server.py",
    "dist": "npm run build && npm run build:backend && electron-builder",
    "dist:win": "npm run build && npm run build:backend && electron-builder --win",
    "dist:linux": "npm run build && npm run build:backend && electron-builder --linux"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "electron": "43.2.0",
    "electron-builder": "26.15.3",
    "electron-vite": "^5.0.0"
  },
  "build": {
    "appId": "com.betterfingers.desktop",
    "productName": "BetterFingers",
    "icon": "build/icon.png",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/uiohook-napi/**"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!.gitkeep"
        ]
      },
      {
        "from": "../assets",
        "to": "assets"
      },
      {
        "from": "../images",
        "to": "images"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": null
  },
  "allowScripts": {
    "electron@43.1.0": true,
    "electron-winstaller@5.4.0": true,
    "esbuild@0.25.12": true,
    "esbuild@0.27.7": true
  },
  "dependencies": {
    "uiohook-napi": "^1.5.5"
  }
}
