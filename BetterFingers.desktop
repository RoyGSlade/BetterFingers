[Desktop Entry]
Type=Application
Name=BetterFingers
Comment=Voice dictation with local transcription, rewrite, and TTS
# Paths below are placeholders. Run scripts/install-linux-shortcut.sh to generate
# a working entry in ~/.local/share/applications with the real repo path filled in.
Exec=@APP_DIR@/scripts/launch-betterfingers-linux.sh
Path=@APP_DIR@
Icon=@APP_DIR@/images/BetterFingers.ico
Terminal=false
Categories=Utility;Accessibility;
StartupNotify=true
