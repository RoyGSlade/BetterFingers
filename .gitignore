# Python cache/artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Test/cache outputs
.pytest_cache/
.cache/
.tmp_pip_meta/
*.log

# Build/package outputs
build/
dist/
app/out/
app/release/
app/node_modules/
app/.electron-backend-build/
app/resources/backend/*
!app/resources/backend/.gitkeep
*.spec.bak

# Local virtual environments
.venv/
venv/
env/

# Local secrets / machine-specific environment
.env
.env.*

# Repo-local runtime assets
.betterfingers/

# Playwright run output (regenerated every run; churns the tree)
app/test-results/
app/playwright-report/
# Per-run QA screenshots. Curated reg-actions baselines get checked in
# deliberately under a separate path, not this one.
app/artifacts/
